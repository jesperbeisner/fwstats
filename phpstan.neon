parameters:
    level: max

    paths:
        - public
        - src
        - tests

    strictRules:
        allRules: true
        strictCalls: false

    type_coverage:
        return_type: 100
        param_type: 100
        property_type: 100
        print_suggestions: false

includes:
    - .phpstan/phpstan-baseline.php

rules:
    - Jesperbeisner\Fwstats\PHPStan\ControllerKeywordsRule
    - Jesperbeisner\Fwstats\PHPStan\ControllerImplementsInterfaceRule
